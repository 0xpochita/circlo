generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────────────────────
model User {
  id             String   @id @default(uuid())
  wallet_address String   @unique
  name           String?
  username       String?  @unique
  avatar_emoji   String?
  avatar_color   String?
  referred_by    String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  referredByUser     User?               @relation("UserReferrals", fields: [referred_by], references: [id])
  referredUsers      User[]              @relation("UserReferrals")
  ownedCircles       Circle[]            @relation("CircleOwner")
  circleMemberships  CircleMember[]
  createdGoals       Goal[]              @relation("GoalCreator")
  goalParticipations GoalParticipant[]
  goalResolutions    GoalResolver[]
  notifications      Notification[]      @relation("NotificationUser")
  actorNotifications Notification[]      @relation("NotificationActor")
  referralsMade      Referral[]          @relation("ReferrerUser")
  referralsReceived  Referral[]          @relation("ReferredUser")

  @@map("users")
}

// ── Circles ───────────────────────────────────────────────────────────────────
model Circle {
  id           String   @id @default(uuid())
  chain_id     BigInt?
  owner_id     String
  name         String
  description  String?
  category     String   // general|crypto|fitness|gaming|music|other
  privacy      String   // public|private
  invite_code  String?  @unique
  avatar_emoji String?
  avatar_color String?
  created_at   DateTime @default(now())

  // Relations
  owner   User           @relation("CircleOwner", fields: [owner_id], references: [id])
  members CircleMember[]
  goals   Goal[]

  @@index([owner_id])
  @@index([category, privacy])
  @@map("circles")
}

// ── Circle Members ─────────────────────────────────────────────────────────────
model CircleMember {
  circle_id String
  user_id   String
  role      String   // owner|admin|member
  joined_at DateTime @default(now())

  circle Circle @relation(fields: [circle_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([circle_id, user_id])
  @@index([user_id])
  @@index([circle_id])
  @@map("circle_members")
}

// ── Goals ─────────────────────────────────────────────────────────────────────
model Goal {
  id           String    @id @default(uuid())
  chain_id     BigInt?
  circle_id    String
  creator_id   String
  title        String
  description  String?
  avatar_emoji String?
  avatar_color String?
  outcome_type String    // binary|multi|numeric
  deadline     DateTime
  min_stake    Decimal   @db.Decimal(36, 6)
  status       String    @default("open") // open|locked|resolving|resolved|disputed|paid_out
  winning_side String?
  metadata_uri String?
  tx_hash      String?
  created_at   DateTime  @default(now())

  // Relations
  circle       Circle            @relation(fields: [circle_id], references: [id])
  creator      User              @relation("GoalCreator", fields: [creator_id], references: [id])
  participants GoalParticipant[]
  resolvers    GoalResolver[]

  @@index([circle_id, status])
  @@index([creator_id])
  @@index([deadline])
  @@map("goals")
}

// ── Goal Participants ──────────────────────────────────────────────────────────
model GoalParticipant {
  goal_id        String
  user_id        String
  side           String  // yes|no or choice id
  staked         Decimal @db.Decimal(36, 6)
  claimed        Boolean @default(false)
  claimed_amount Decimal? @db.Decimal(36, 6)
  created_at     DateTime @default(now())

  goal Goal @relation(fields: [goal_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([goal_id, user_id])
  @@index([user_id])
  @@index([goal_id, side])
  @@map("goal_participants")
}

// ── Goal Resolvers ────────────────────────────────────────────────────────────
model GoalResolver {
  goal_id  String
  user_id  String
  vote     String?
  voted_at DateTime?

  goal Goal @relation(fields: [goal_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([goal_id, user_id])
  @@map("goal_resolvers")
}

// ── Notifications ─────────────────────────────────────────────────────────────
model Notification {
  id          String   @id @default(uuid())
  user_id     String
  type        String
  actor_id    String?
  entity_type String?
  entity_id   String?
  title       String
  description String
  unread      Boolean  @default(true)
  created_at  DateTime @default(now())

  user  User  @relation("NotificationUser", fields: [user_id], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([user_id, unread, created_at(sort: Desc)])
  @@map("notifications")
}

// ── Referrals ─────────────────────────────────────────────────────────────────
model Referral {
  id              String    @id @default(uuid())
  referrer_id     String
  referred_id     String
  status          String    @default("pending") // pending|verified|rewarded
  verified_at     DateTime?
  reward_tx_hash  String?

  referrer User @relation("ReferrerUser", fields: [referrer_id], references: [id])
  referred User @relation("ReferredUser", fields: [referred_id], references: [id])

  @@unique([referrer_id, referred_id])
  @@map("referrals")
}

// ── Indexer State ─────────────────────────────────────────────────────────────
model IndexerState {
  contract   String   @id
  last_block BigInt
  updated_at DateTime @updatedAt

  @@map("indexer_state")
}
