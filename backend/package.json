{
  "name": "circlo-backend",
  "version": "1.0.0",
  "description": "Circlo - Social Prediction Game Backend (Celo Blockchain)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:indexer": "tsx watch src/indexer/index.ts",
    "dev:jobs": "tsx watch src/jobs/index.ts",
    "build": "tsc --noEmit",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.2",
    "siwe": "^2.3.2",
    "uuid": "^10.0.0",
    "viem": "^2.21.54",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
